<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rhythm Mapper - Admin Panel</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(120deg, #f4efe6 0%, #e8dfd1 45%, #e6ede4 100%);
            color: #2c2c2c;
        }
        body.dark-mode {
            background: linear-gradient(120deg, #1f1f1b 0%, #252a2c 45%, #1b2321 100%);
            color: #ece6d6;
        }
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 18px;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
        }
        body.dark-mode .header,
        body.dark-mode .panel,
        body.dark-mode .stat-card {
            background: rgba(35, 39, 46, 0.95);
            color: #ece6d6;
        }
        .header h1 {
            margin: 0 0 8px;
            color: #3f5468;
        }
        body.dark-mode .header h1 { color: #8dc3ff; }
        .header p {
            margin: 0;
            line-height: 1.4;
            opacity: 0.9;
        }
        .header-actions {
            margin-top: 14px;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        .btn {
            border: none;
            border-radius: 8px;
            padding: 10px 14px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
        }
        .btn-primary { background: #2f7bd7; color: #fff; }
        .btn-secondary { background: #6c757d; color: #fff; }
        .btn-success { background: #2f9e5a; color: #fff; }
        .btn-warning { background: #d48a10; color: #fff; }
        .btn-danger { background: #bf3535; color: #fff; }
        .alert {
            display: none;
            padding: 10px 12px;
            border-radius: 8px;
            margin-bottom: 14px;
            font-size: 14px;
        }
        .alert.info { background: #e7f1ff; color: #0d47a1; }
        .alert.success { background: #e7f8ed; color: #176738; }
        .alert.error { background: #fdecec; color: #a31616; }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 12px;
            margin-bottom: 18px;
        }
        .stat-card {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 10px;
            padding: 14px;
            box-shadow: 0 3px 12px rgba(0, 0, 0, 0.08);
            text-align: center;
        }
        .stat-card .value {
            font-size: 26px;
            font-weight: 700;
            margin-top: 4px;
        }
        .main-grid {
            display: grid;
            grid-template-columns: 1.05fr 1fr;
            gap: 16px;
        }
        .panel {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 12px;
            padding: 16px;
            box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
        }
        .panel h2 {
            margin: 0 0 14px;
            font-size: 20px;
            color: #3f5468;
        }
        body.dark-mode .panel h2 { color: #8dc3ff; }
        .row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
            margin-bottom: 10px;
        }
        input[type="text"], input[type="number"], select, textarea {
            border: 1px solid #c8d0d9;
            border-radius: 8px;
            padding: 8px 10px;
            font-size: 14px;
            background: #fff;
            color: #222;
        }
        body.dark-mode input[type="text"],
        body.dark-mode input[type="number"],
        body.dark-mode select,
        body.dark-mode textarea {
            background: #2c3138;
            border-color: #3d4652;
            color: #ece6d6;
        }
        .grow { flex: 1 1 220px; }
        .song-table-wrap,
        .set-table-wrap {
            max-height: 320px;
            overflow: auto;
            border: 1px solid #d9dfe6;
            border-radius: 8px;
        }
        body.dark-mode .song-table-wrap,
        body.dark-mode .set-table-wrap {
            border-color: #3d4652;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        th, td {
            border-bottom: 1px solid #eceff3;
            padding: 8px;
            text-align: left;
            vertical-align: top;
        }
        body.dark-mode th, body.dark-mode td { border-bottom-color: #3b4049; }
        th {
            position: sticky;
            top: 0;
            background: #f3f6fa;
            z-index: 1;
        }
        body.dark-mode th { background: #2b3037; }
        .current-song {
            border: 1px solid #d4dde7;
            border-radius: 8px;
            padding: 10px;
            margin-bottom: 10px;
            font-size: 13px;
        }
        body.dark-mode .current-song { border-color: #3d4652; }
        .preview-buttons {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin: 8px 0;
        }
        .preview-buttons .btn { padding: 8px 11px; font-size: 13px; }
        .small-note {
            font-size: 12px;
            opacity: 0.8;
        }
        .inline-actions {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }
        .loop-preview-buttons {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
        }
        .loop-preview-buttons .btn {
            padding: 4px 8px;
            font-size: 11px;
            min-width: 50px;
        }
        textarea { width: 100%; min-height: 50px; }
        
        /* Quick Create Modal */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.active {
            display: flex;
        }
        .modal-content {
            background: white;
            border-radius: 12px;
            padding: 24px;
            max-width: 800px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }
        body.dark-mode .modal-content {
            background: #2b3037;
            color: #ece6d6;
        }
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #e0e0e0;
        }
        body.dark-mode .modal-header {
            border-bottom-color: #3d4652;
        }
        .modal-header h2 {
            margin: 0;
            color: #3f5468;
        }
        body.dark-mode .modal-header h2 {
            color: #8dc3ff;
        }
        .modal-close {
            background: none;
            border: none;
            font-size: 28px;
            cursor: pointer;
            color: #666;
            padding: 0;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
        }
        .modal-close:hover {
            background: #f0f0f0;
        }
        body.dark-mode .modal-close {
            color: #aaa;
        }
        body.dark-mode .modal-close:hover {
            background: #3d4652;
        }
        .modal-section {
            margin-bottom: 24px;
            padding: 16px;
            background: #f9f9f9;
            border-radius: 8px;
        }
        body.dark-mode .modal-section {
            background: #1f2329;
        }
        .modal-section h3 {
            margin: 0 0 12px 0;
            font-size: 16px;
            color: #3f5468;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        body.dark-mode .modal-section h3 {
            color: #8dc3ff;
        }
        .step-indicator {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            background: #2f7bd7;
            color: white;
            border-radius: 50%;
            font-size: 12px;
            font-weight: bold;
        }
        .step-indicator.complete {
            background: #2f9e5a;
        }
        .upload-area {
            border: 2px dashed #ccc;
            border-radius: 8px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        .upload-area:hover {
            border-color: #2f7bd7;
            background: rgba(47, 123, 215, 0.05);
        }
        .upload-area.dragover {
            border-color: #2f7bd7;
            background: rgba(47, 123, 215, 0.1);
        }
        .file-list {
            list-style: none;
            padding: 0;
            margin: 12px 0 0 0;
        }
        .file-list li {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 12px;
            background: white;
            border-radius: 6px;
            margin-bottom: 6px;
        }
        body.dark-mode .file-list li {
            background: #2b3037;
        }
        .file-list .remove-file {
            color: #bf3535;
            cursor: pointer;
            font-size: 18px;
        }
        .song-selector {
            max-height: 200px;
            overflow-y: auto;
            border: 1px solid #ddd;
            border-radius: 6px;
            padding: 8px;
        }
        body.dark-mode .song-selector {
            border-color: #3d4652;
        }
        .song-checkbox-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px;
            border-radius: 4px;
        }
        .song-checkbox-item:hover {
            background: rgba(47, 123, 215, 0.1);
        }
        .modal-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 24px;
            padding-top: 16px;
            border-top: 2px solid #e0e0e0;
        }
        body.dark-mode .modal-actions {
            border-top-color: #3d4652;
        }
        .progress-message {
            padding: 12px;
            background: #e7f1ff;
            border-left: 4px solid #2f7bd7;
            border-radius: 4px;
            margin: 12px 0;
            display: none;
        }
        .progress-message.active {
            display: block;
        }
        body.dark-mode .progress-message {
            background: #1a2530;
        }
        @media (max-width: 980px) {
            .main-grid { grid-template-columns: 1fr; }
            .song-table-wrap, .set-table-wrap { max-height: 260px; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1><i class="fas fa-wave-square"></i> Rhythm Mapper</h1>
            <p>Map songs to deterministic rhythm sets and preview loops while assigning, without using the popup admin panel.</p>
            <div class="header-actions">
                <button id="quickCreateBtn" class="btn btn-success" style="font-weight:bold;"><i class="fas fa-bolt"></i> Quick Create Rhythm Set</button>
                <button id="refreshAllBtn" class="btn btn-primary"><i class="fas fa-rotate"></i> Refresh</button>
                <a class="btn btn-secondary" href="index.html" style="text-decoration:none; display:inline-flex; align-items:center; gap:8px;"><i class="fas fa-arrow-left"></i> Back To App</a>
                <a class="btn btn-secondary" href="loop-manager.html" target="_blank" style="text-decoration:none; display:inline-flex; align-items:center; gap:8px;"><i class="fas fa-drum"></i> Loop Manager</a>
            </div>
        </div>

        <div id="pageAlert" class="alert"></div>

        <div class="stats-grid">
            <div class="stat-card"><div>Rhythm Sets</div><div class="value" id="statRhythmSets">0</div></div>
            <div class="stat-card"><div>Mapped Songs</div><div class="value" id="statMappedSongs">0</div></div>
            <div class="stat-card"><div>Unmapped Songs</div><div class="value" id="statUnmappedSongs">0</div></div>
            <div class="stat-card"><div>Complete Sets</div><div class="value" id="statCompleteSets">0</div></div>
        </div>

        <div class="main-grid">
            <section class="panel">
                <h2><i class="fas fa-link"></i> Song Mapping</h2>
                <div class="row">
                    <input id="songSearchInput" class="grow" type="text" placeholder="Search songs by title, id, taal, or rhythm set...">
                    <button id="selectAllBtn" class="btn btn-secondary"><i class="fas fa-check-double"></i> Select All</button>
                    <button id="clearSelectionBtn" class="btn btn-secondary"><i class="fas fa-times"></i> Clear</button>
                </div>
                <div class="song-table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th><input type="checkbox" id="selectAllCheckbox" title="Select/Deselect All"></th>
                                <th>Song</th>
                                <th>Current Rhythm Set</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="songsTableBody"></tbody>
                    </table>
                </div>

                <div class="current-song" id="selectedSongCard">
                    No songs selected. Select one or more songs to start mapping.
                </div>

                <div class="row">
                    <select id="mapperRhythmSetSelect" class="grow"></select>
                    <button id="recommendBtn" class="btn btn-warning"><i class="fas fa-lightbulb"></i> Recommend</button>
                    <button id="assignBtn" class="btn btn-success"><i class="fas fa-check"></i> Assign to Selected</button>
                </div>
                <div class="small-note" id="selectedSetMeta">Pick a rhythm set to preview and assign to selected song(s).</div>

                <div class="preview-buttons" id="previewButtons"></div>
                <div class="row">
                    <button id="stopPreviewBtn" class="btn btn-secondary"><i class="fas fa-stop"></i> Stop Preview</button>
                </div>
            </section>

            <section class="panel">
                <h2><i class="fas fa-sliders"></i> Rhythm Set Management</h2>
                <div class="small-note" style="margin-bottom:10px;">
                    Rename using only the <strong>Rhythm Set Name</strong> field in format <code>family_setNo</code> (example: <code>keherwa_2</code>).
                    Click any loop button in the Preview Loops column to hear the rhythm.
                </div>
                <div style="margin-bottom:10px;">
                    <button id="stopAllPreviewBtn" class="btn btn-secondary"><i class="fas fa-stop"></i> Stop All Previews</button>
                </div>
                <form id="createRhythmSetForm">
                    <div class="row">
                        <input id="createFamily" type="text" placeholder="rhythm family (e.g. keherwa)" class="grow" required>
                        <input id="createSetNo" type="number" placeholder="set no" min="1" step="1" style="width:110px;" required>
                        <select id="createStatus" style="width:140px;">
                            <option value="active">active</option>
                            <option value="inactive">inactive</option>
                            <option value="archived">archived</option>
                        </select>
                    </div>
                    <div class="row">
                        <input id="createNotes" type="text" class="grow" placeholder="optional notes">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Create</button>
                    </div>
                </form>

                <div class="set-table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Rhythm Set Name</th>
                                <th>Mapped</th>
                                <th>Files</th>
                                <th>Status</th>
                                <th>Notes</th>
                                <th>Preview Loops</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="rhythmSetsTableBody"></tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>

    <!-- Quick Create Modal -->
    <div class="modal-overlay" id="quickCreateModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2><i class="fas fa-bolt"></i> Quick Create Rhythm Set</h2>
                <button class="modal-close" id="closeQuickCreate">&times;</button>
            </div>

            <div id="quickCreateProgress" class="progress-message"></div>

            <!-- Step 1: Create Rhythm Set -->
            <div class="modal-section">
                <h3>
                    <span class="step-indicator" id="step1Indicator">1</span>
                    Create Rhythm Set
                </h3>
                <div class="row">
                    <input id="qc_rhythmFamily" type="text" placeholder="Rhythm family (e.g., keherwa, dadra)" class="grow" required>
                    <select id="qc_rhythmSetNo" style="width:120px;" required>
                        <option value="">Set #</option>
                    </select>
                </div>
                <div class="row" style="margin-top:8px;">
                    <select id="qc_status" style="width:140px;">
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                        <option value="archived">Archived</option>
                    </select>
                    <input id="qc_notes" type="text" class="grow" placeholder="Optional notes">
                </div>
                <div id="qc_rhythmSetPreview" style="margin-top:8px; padding:8px; background:rgba(47,123,215,0.1); border-radius:6px; display:none;">
                    <strong>Rhythm Set Name:</strong> <span id="qc_rhythmSetName">-</span>
                </div>
                <div id="qc_existingLoops" style="margin-top:8px; display:none;">
                    <div class="small-note" style="margin-bottom:4px;"><strong>Existing loops for this family:</strong></div>
                    <div id="qc_existingLoopsList" style="font-size:12px; color:#666;"></div>
                </div>
            </div>

            <!-- Step 2: Upload Loops -->
            <div class="modal-section">
                <h3>
                    <span class="step-indicator" id="step2Indicator">2</span>
                    Upload Loop Files (Optional)
                </h3>
                <p class="small-note" style="margin:0 0 12px 0;">
                    Upload loop1, loop2, loop3, fill1, fill2, fill3 MP3 files. You can skip this and upload later.
                </p>
                <div class="upload-area" id="uploadArea">
                    <i class="fas fa-cloud-upload-alt" style="font-size:48px; color:#2f7bd7; margin-bottom:12px;"></i>
                    <p style="margin:0;">Click or drag & drop MP3 files here</p>
                    <input type="file" id="loopFilesInput" accept=".mp3,audio/mpeg" multiple style="display:none;">
                </div>
                <ul class="file-list" id="fileList"></ul>
            </div>

            <!-- Step 3: Assign Songs -->
            <div class="modal-section">
                <h3>
                    <span class="step-indicator" id="step3Indicator">3</span>
                    Assign Songs (Optional)
                </h3>
                <p class="small-note" style="margin:0 0 12px 0;">
                    Select songs to assign to this rhythm set. You can skip this and assign later.
                </p>
                <div style="margin-bottom:12px;">
                    <input type="text" id="qc_songSearch" class="grow" placeholder="Search songs by title, taal, key...">
                </div>
                <div class="song-selector" id="songSelector">
                    <p style="margin:0; text-align:center; color:#999;">Loading songs...</p>
                </div>
                <div style="margin-top:8px; font-size:12px; color:#666;">
                    <span id="selectedSongsCount">0</span> songs selected
                </div>
            </div>

            <!-- Actions -->
            <div class="modal-actions">
                <button class="btn btn-secondary" id="cancelQuickCreate">Cancel</button>
                <button class="btn btn-success" id="executeQuickCreate"><i class="fas fa-rocket"></i> Create & Assign</button>
            </div>
        </div>
    </div>

    <script src="rhythm-sets-manager.js"></script>
</body>
</html>
