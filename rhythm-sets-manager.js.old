const API_BASE_URL = (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1')
    ? 'http://localhost:3001'
    : (window.location.hostname.endsWith('github.io')
        ? 'https://oldand-new.vercel.app'
        : window.location.origin);

const RHYTHM_FILE_ORDER = ['loop1', 'loop2', 'loop3', 'fill1', 'fill2', 'fill3'];

let songs = [];
let rhythmSets = [];
let filteredSongs = [];
let loopsByRhythmSet = new Map();
let selectedSongIds = new Set();
let currentAudio = null;

function applyThemeFromStorage() {
    if (localStorage.getItem('darkMode') === 'true') {
        document.body.classList.add('dark-mode');
    }
}

function getAuthToken() {
    return localStorage.getItem('jwtToken') || '';
}

function isAuthenticated() {
    return Boolean(getAuthToken());
}

function normalizeRhythmFamily(value) {
    if (typeof value !== 'string') return '';
    return value
        .trim()
        .toLowerCase()
        .replace(/\s+/g, '_')
        .replace(/[^a-z0-9_-]/g, '');
}

function parseRhythmSetId(rhythmSetId) {
    const match = String(rhythmSetId || '').trim().toLowerCase().match(/^([a-z0-9_-]+)_([0-9]+)$/);
    if (!match) return null;
    return {
        rhythmFamily: normalizeRhythmFamily(match[1]),
        rhythmSetNo: parseInt(match[2], 10),
        rhythmSetId: `${normalizeRhythmFamily(match[1])}_${parseInt(match[2], 10)}`
    };
}

function buildRhythmSetId(rhythmFamily, rhythmSetNo) {
    const parsedNo = parseInt(rhythmSetNo, 10);
    const normalizedFamily = normalizeRhythmFamily(rhythmFamily);
    if (!normalizedFamily || !Number.isInteger(parsedNo) || parsedNo <= 0) return '';
    return `${normalizedFamily}_${parsedNo}`;
}

function showAlert(message, type = 'info') {
    const alert = document.getElementById('pageAlert');
    if (!alert) return;
    alert.textContent = message;
    alert.className = `alert ${type}`;
    alert.style.display = 'block';
}

function clearAlertAfter(ms = 2500) {
    const alert = document.getElementById('pageAlert');
    if (!alert) return;
    window.setTimeout(() => {
        alert.style.display = 'none';
    }, ms);
}

async function authFetch(url, options = {}) {
    const headers = options.headers || {};
    const token = getAuthToken();
    if (token) {
        headers.Authorization = `Bearer ${token}`;
    }
    const requestOptions = { ...options };
    if (!requestOptions.cache) {
        requestOptions.cache = 'no-store';
    }
    return fetch(url, { ...requestOptions, headers });
}

function escapeHtml(value) {
    return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function setStats() {
    const mappedSongs = songs.filter(song => song.rhythmSetId).length;
    const completeSets = rhythmSets.filter(set => set.isComplete).length;

    document.getElementById('statRhythmSets').textContent = String(rhythmSets.length);
    document.getElementById('statMappedSongs').textContent = String(mappedSongs);
    document.getElementById('statUnmappedSongs').textContent = String(Math.max(0, songs.length - mappedSongs));
    document.getElementById('statCompleteSets').textContent = String(completeSets);
}

function resolveLoopRhythmSetId(loop) {
    if (loop && loop.rhythmSetId) return String(loop.rhythmSetId).toLowerCase();
    const family = normalizeRhythmFamily((loop && (loop.rhythmFamily || (loop.conditions && loop.conditions.taal))) || '');
    const setNo = parseInt((loop && (loop.rhythmSetNo || loop.setNo)) || 1, 10);
    return buildRhythmSetId(family, setNo);
}

async function loadLoopsMetadata() {
    const response = await fetch(`${API_BASE_URL}/api/loops/metadata`);
    if (!response.ok) {
        throw new Error('Failed to load loops metadata');
    }

    const metadata = await response.json();
    const map = new Map();
    const loops = Array.isArray(metadata.loops) ? metadata.loops : [];

    loops.forEach(loop => {
        const rhythmSetId = resolveLoopRhythmSetId(loop);
        if (!rhythmSetId) return;

        if (!map.has(rhythmSetId)) {
            map.set(rhythmSetId, {});
        }

        const key = `${loop.type}${loop.number}`;
        if (loop.filename && key) {
            map.get(rhythmSetId)[key] = loop.filename;
        }
    });

    loopsByRhythmSet = map;
}

async function loadRhythmSets() {
    const response = await authFetch(`${API_BASE_URL}/api/rhythm-sets`);
    if (!response.ok) {
        const err = await response.json().catch(() => ({ error: 'Failed to load rhythm sets' }));
        throw new Error(err.error || 'Failed to load rhythm sets');
    }

    rhythmSets = await response.json();
    renderRhythmSetSelect();
    renderRhythmSetsTable();
}

async function loadSongs() {
    const response = await authFetch(`${API_BASE_URL}/api/songs`);
    if (!response.ok) {
        const err = await response.json().catch(() => ({ error: 'Failed to load songs' }));
        throw new Error(err.error || 'Failed to load songs');
    }

    songs = await response.json();
    songs.sort((a, b) => String(a.title || '').localeCompare(String(b.title || '')));
    filteredSongs = songs.slice();
    renderSongsTable();
}

function renderSongsTable() {
    const tbody = document.getElementById('songsTableBody');
    tbody.innerHTML = '';

    if (!filteredSongs.length) {
        const tr = document.createElement('tr');
        tr.innerHTML = '<td colspan="4">No songs match the current filter.</td>';
        tbody.appendChild(tr);
        return;
    }

    filteredSongs.forEach(song => {
        const tr = document.createElement('tr');
        const isSelected = selectedSongIds.has(Number(song.id));
        if (isSelected) {
            tr.style.background = 'rgba(47,123,215,0.12)';
        }

        tr.innerHTML = `
            <td><input type="checkbox" class="song-checkbox" data-song-id="${escapeHtml(song.id)}" ${isSelected ? 'checked' : ''}></td>
            <td>
                <strong>${escapeHtml(song.title || '(untitled)')}</strong>
                <div class="small-note">ID: ${escapeHtml(song.id)} | Taal: ${escapeHtml(song.taal || '-')}</div>
            </td>
            <td>${escapeHtml(song.rhythmSetId || '-')}</td>
            <td><button class="btn btn-primary select-song-btn" data-song-id="${escapeHtml(song.id)}">${isSelected ? 'Deselect' : 'Select'}</button></td>
        `;
        tbody.appendChild(tr);
    });
    
    updateSelectAllCheckbox();
}

function renderRhythmSetSelect() {
    const select = document.getElementById('mapperRhythmSetSelect');
    const previousValue = select.value;

    select.innerHTML = '<option value="">Select rhythm set...</option>';
    rhythmSets.forEach(set => {
        const option = document.createElement('option');
        option.value = set.rhythmSetId;
        option.textContent = `${set.rhythmSetId} (${set.mappedSongCount || 0} songs)`;
        select.appendChild(option);
    });

    if (previousValue && rhythmSets.some(set => set.rhythmSetId === previousValue)) {
        select.value = previousValue;
    }
}

function renderRhythmSetsTable() {
    const tbody = document.getElementById('rhythmSetsTableBody');
    tbody.innerHTML = '';

    if (!rhythmSets.length) {
        const tr = document.createElement('tr');
        tr.innerHTML = '<td colspan="7">No rhythm sets available.</td>';
        tbody.appendChild(tr);
        return;
    }

    rhythmSets.forEach(set => {
        const tr = document.createElement('tr');
        tr.dataset.rhythmSetId = set.rhythmSetId;

        const statusOptions = ['active', 'inactive', 'archived'];
        if (set.status && !statusOptions.includes(set.status)) {
            statusOptions.push(set.status);
        }

        // Generate preview buttons for available loops
        const loopFiles = loopsByRhythmSet.get(String(set.rhythmSetId || '').toLowerCase()) || {};
        const hasLoops = Object.keys(loopFiles).length > 0;
        const previewButtonsHtml = RHYTHM_FILE_ORDER.map(fileKey => {
            const filename = loopFiles[fileKey];
            if (!filename) return '';
            return `<button class="btn btn-secondary preview-loop-btn" data-filename="${escapeHtml(filename)}" data-label="${escapeHtml(fileKey)}" title="Preview ${fileKey}"><i class="fas fa-play"></i> ${fileKey.toUpperCase()}</button>`;
        }).filter(Boolean).join('');

        const previewCell = previewButtonsHtml 
            ? `<div class="loop-preview-buttons">${previewButtonsHtml}</div>`
            : '<span class="small-note">No loops</span>';

        // Determine source badge
        const isInDatabase = set._id || set.createdAt; // Has database fields
        const sourceBadge = !isInDatabase && hasLoops 
            ? '<span style="background:#ff9800; color:white; padding:2px 6px; border-radius:4px; font-size:10px; margin-left:6px;" title="Only exists in loop files, not in database">LOOPS ONLY</span>'
            : '';

        tr.innerHTML = `
            <td>
                <strong>${escapeHtml(set.rhythmSetId)}</strong>${sourceBadge}
                <div class="small-note" style="margin-top:6px; display:flex; gap:6px; flex-wrap:wrap; align-items:center;">
                    <input class="set-id" type="text" value="${escapeHtml(set.rhythmSetId || '')}" placeholder="family_setNo (example: keherwa_2)" style="min-width:220px;">
                    <span>family: ${escapeHtml(set.rhythmFamily || '-')}</span>
                    <span>set: ${escapeHtml(set.rhythmSetNo || '-')}</span>
                </div>
            </td>
            <td>${escapeHtml(set.mappedSongCount || 0)}</td>
            <td>${escapeHtml((set.availableFiles || []).length)}/6</td>
            <td>
                <select class="set-status">
                    ${statusOptions.map(status => `<option value="${escapeHtml(status)}" ${String(set.status || 'active') === status ? 'selected' : ''}>${escapeHtml(status)}</option>`).join('')}
                </select>
            </td>
            <td><textarea class="set-notes">${escapeHtml(set.notes || '')}</textarea></td>
            <td>${previewCell}</td>
            <td>
                <div class="inline-actions">
                    <button class="btn btn-success save-set-btn">Save</button>
                    <button class="btn btn-primary rename-set-btn">Save Name</button>
                    <button class="btn btn-warning recompute-set-btn">Recompute</button>
                    <button class="btn btn-secondary use-set-btn">Use</button>
                    <button class="btn btn-danger delete-set-btn" title="Delete this rhythm set">Delete</button>
                </div>
            </td>
        `;
        tbody.appendChild(tr);
    });
}

function getRenamePayloadFromRow(row) {
    const rhythmSetIdInput = row.querySelector('.set-id');
    const directId = String(rhythmSetIdInput ? rhythmSetIdInput.value : '').trim();
    const parsedId = parseRhythmSetId(directId);

    if (!parsedId) {
        throw new Error('Rhythm Set Name must be in format family_setNo (example: keherwa_2).');
    }

    return {
        rhythmFamily: parsedId.rhythmFamily,
        rhythmSetNo: parsedId.rhythmSetNo,
        newRhythmSetId: parsedId.rhythmSetId
    };
}

function setSelectedSong(songId) {
    const normalizedId = Number(songId);
    const song = songs.find(item => Number(item.id) === normalizedId);
    if (!song) return;

    // Toggle selection
    if (selectedSongIds.has(normalizedId)) {
        selectedSongIds.delete(normalizedId);
    } else {
        selectedSongIds.add(normalizedId);
    }
    
    renderSongsTable();
    updateSelectedSongCard();
}

function updateSelectAllCheckbox() {
    const checkbox = document.getElementById('selectAllCheckbox');
    if (!checkbox) return;
    
    const visibleSongIds = filteredSongs.map(s => Number(s.id));
    const allSelected = visibleSongIds.length > 0 && visibleSongIds.every(id => selectedSongIds.has(id));
    const someSelected = visibleSongIds.some(id => selectedSongIds.has(id));
    
    checkbox.checked = allSelected;
    checkbox.indeterminate = someSelected && !allSelected;
}

function updateSelectedSongCard() {
    const card = document.getElementById('selectedSongCard');
    
    if (selectedSongIds.size === 0) {
        card.innerHTML = 'No songs selected. Select one or more songs to start mapping.';
        return;
    }
    
    const selectedSongs = songs.filter(s => selectedSongIds.has(Number(s.id)));
    
    if (selectedSongs.length === 1) {
        const song = selectedSongs[0];
        card.innerHTML = `
            <div><strong>${escapeHtml(song.title || '(untitled)')}</strong></div>
            <div class="small-note">ID: ${escapeHtml(song.id)} | Current Rhythm Set: ${escapeHtml(song.rhythmSetId || '-')}</div>
            <div class="small-note">Taal: ${escapeHtml(song.taal || '-')} | Time: ${escapeHtml(song.time || song.timeSignature || '-')} | Tempo: ${escapeHtml(song.tempo || '-')}</div>
        `;
        
        const select = document.getElementById('mapperRhythmSetSelect');
        if (song.rhythmSetId && rhythmSets.some(set => set.rhythmSetId === song.rhythmSetId)) {
            select.value = song.rhythmSetId;
        }
        
        updateSelectedSetMeta();
        renderPreviewButtons(select.value || song.rhythmSetId || '');
    } else {
        const rhythmSetCounts = {};
        selectedSongs.forEach(song => {
            const rsId = song.rhythmSetId || 'unmapped';
            rhythmSetCounts[rsId] = (rhythmSetCounts[rsId] || 0) + 1;
        });
        
        const countSummary = Object.entries(rhythmSetCounts)
            .map(([rsId, count]) => `${rsId}: ${count}`)
            .join(', ');
        
        card.innerHTML = `
            <div><strong>${selectedSongs.length} songs selected</strong></div>
            <div class="small-note">Current rhythm sets: ${countSummary}</div>
            <div class="small-note">Ready to assign all selected songs to the same rhythm set</div>
        `;
        
        updateSelectedSetMeta();
        
        // Show preview for the first selected song's rhythm set if available
        const firstSong = selectedSongs[0];
        const select = document.getElementById('mapperRhythmSetSelect');
        renderPreviewButtons(select.value || firstSong.rhythmSetId || '');
    }
}

function updateSelectedSetMeta() {
    const select = document.getElementById('mapperRhythmSetSelect');
    const info = document.getElementById('selectedSetMeta');
    const rhythmSet = rhythmSets.find(set => set.rhythmSetId === select.value);

    if (!rhythmSet) {
        info.textContent = 'Pick a rhythm set to preview and assign to selected song(s).';
        return;
    }

    const fileCount = Array.isArray(rhythmSet.availableFiles) ? rhythmSet.availableFiles.length : 0;
    info.textContent = `${rhythmSet.rhythmSetId} | status: ${rhythmSet.status || 'active'} | mapped songs: ${rhythmSet.mappedSongCount || 0} | files: ${fileCount}/6`;
}

function stopPreview() {
    if (currentAudio) {
        currentAudio.pause();
        currentAudio = null;
    }
    document.querySelectorAll('.preview-play i').forEach(icon => {
        icon.className = 'fas fa-play';
    });
}

function playPreview(url, button) {
    const icon = button.querySelector('i');

    if (currentAudio && currentAudio.src === url && !currentAudio.paused) {
        stopPreview();
        return;
    }

    stopPreview();
    currentAudio = new Audio(url);
    currentAudio.play();
    icon.className = 'fas fa-pause';

    currentAudio.addEventListener('ended', () => {
        icon.className = 'fas fa-play';
    }, { once: true });
}

function renderPreviewButtons(rhythmSetId) {
    const container = document.getElementById('previewButtons');
    container.innerHTML = '';

    const files = loopsByRhythmSet.get(String(rhythmSetId || '').toLowerCase()) || null;
    if (!files) {
        container.innerHTML = '<span class="small-note">No loop files available for this rhythm set yet.</span>';
        return;
    }

    RHYTHM_FILE_ORDER.forEach(fileKey => {
        const filename = files[fileKey];
        if (!filename) return;

        const btn = document.createElement('button');
        btn.className = 'btn btn-secondary preview-play';
        btn.type = 'button';
        btn.innerHTML = `<i class="fas fa-play"></i> ${fileKey.toUpperCase()}`;
        btn.addEventListener('click', () => {
            const url = `${API_BASE_URL}/loops/${encodeURIComponent(filename)}`;
            playPreview(url, btn);
        });
        container.appendChild(btn);
    });

    if (!container.children.length) {
        container.innerHTML = '<span class="small-note">No loop files available for this rhythm set yet.</span>';
    }
}

function filterSongs() {
    const q = String(document.getElementById('songSearchInput').value || '').trim().toLowerCase();
    if (!q) {
        filteredSongs = songs.slice();
        renderSongsTable();
        return;
    }

    filteredSongs = songs.filter(song => {
        const haystack = [
            song.title,
            song.id,
            song.taal,
            song.rhythmSetId,
            song.rhythmFamily,
            song.time,
            song.timeSignature
        ].map(value => String(value || '').toLowerCase()).join(' ');

        return haystack.includes(q);
    });

    renderSongsTable();
}

async function assignSelectedRhythmSet() {
    if (selectedSongIds.size === 0) {
        showAlert('Select at least one song first.', 'error');
        return;
    }

    const select = document.getElementById('mapperRhythmSetSelect');
    const rhythmSetId = select.value;
    const parsed = parseRhythmSetId(rhythmSetId);

    if (!parsed) {
        showAlert('Select a valid rhythm set first.', 'error');
        return;
    }

    const songCount = selectedSongIds.size;
    const songText = songCount === 1 ? 'song' : 'songs';
    
    showAlert(`Assigning rhythm set to ${songCount} ${songText}...`, 'info');
    
    let successCount = 0;
    let failureCount = 0;
    
    // Process all selected songs
    for (const songId of selectedSongIds) {
        try {
            const response = await authFetch(`${API_BASE_URL}/api/songs/${songId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    rhythmSetId: parsed.rhythmSetId,
                    rhythmFamily: parsed.rhythmFamily,
                    rhythmSetNo: parsed.rhythmSetNo
                })
            });

            if (response.ok) {
                successCount++;
            } else {
                failureCount++;
                console.error(`Failed to map song ${songId}`);
            }
        } catch (error) {
            failureCount++;
            console.error(`Error mapping song ${songId}:`, error);
        }
    }

    if (failureCount === 0) {
        showAlert(`Successfully mapped ${successCount} ${songText}.`, 'success');
    } else if (successCount === 0) {
        showAlert(`Failed to map all ${songCount} ${songText}.`, 'error');
    } else {
        showAlert(`Mapped ${successCount} ${songText}, ${failureCount} failed.`, 'error');
    }
    
    clearAlertAfter();

    await Promise.all([loadSongs(), loadRhythmSets()]);
    
    // Keep selection after assignment
    updateSelectedSongCard();
    setStats();
}

async function recommendForSelectedSong() {
    if (selectedSongIds.size === 0) {
        showAlert('Select at least one song first.', 'error');
        return;
    }

    // Get the first selected song for recommendation
    const firstSongId = Array.from(selectedSongIds)[0];
    const song = songs.find(item => Number(item.id) === Number(firstSongId));
    if (!song) {
        showAlert('Selected song not found.', 'error');
        return;
    }

    showAlert('Calculating recommendation...', 'info');
    const response = await authFetch(`${API_BASE_URL}/api/rhythm-sets/recommend`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(song)
    });

    if (!response.ok) {
        const err = await response.json().catch(() => ({ error: 'No recommendation available' }));
        showAlert(err.error || 'No recommendation available', 'error');
        return;
    }

    const recommendation = await response.json();
    const select = document.getElementById('mapperRhythmSetSelect');
    if (recommendation.rhythmSetId && rhythmSets.some(set => set.rhythmSetId === recommendation.rhythmSetId)) {
        select.value = recommendation.rhythmSetId;
        updateSelectedSetMeta();
        renderPreviewButtons(select.value);
        
        if (selectedSongIds.size === 1) {
            showAlert(`Recommended: ${recommendation.rhythmSetId}`, 'success');
        } else {
            showAlert(`Recommended for first selected song: ${recommendation.rhythmSetId}`, 'success');
        }
        clearAlertAfter();
    } else {
        showAlert('Recommendation returned, but set was not found in current list.', 'error');
    }
}

async function createRhythmSet() {
    const family = document.getElementById('createFamily').value;
    const setNo = parseInt(document.getElementById('createSetNo').value, 10);
    const status = document.getElementById('createStatus').value;
    const notes = document.getElementById('createNotes').value;

    if (!family || !setNo || setNo <= 0) {
        showAlert('Family and positive set number are required.', 'error');
        return;
    }

    const response = await authFetch(`${API_BASE_URL}/api/rhythm-sets`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            rhythmFamily: family,
            rhythmSetNo: setNo,
            status,
            notes
        })
    });

    if (!response.ok) {
        const err = await response.json().catch(() => ({ error: 'Failed to create rhythm set' }));
        showAlert(err.error || 'Failed to create rhythm set', 'error');
        return;
    }

    document.getElementById('createSetNo').value = '';
    document.getElementById('createNotes').value = '';

    showAlert('Rhythm set created.', 'success');
    clearAlertAfter();
    await loadRhythmSets();
    setStats();
}

async function saveRhythmSetRow(row) {
    const rhythmSetId = row.dataset.rhythmSetId;
    const status = row.querySelector('.set-status').value;
    const notes = row.querySelector('.set-notes').value;
    const { rhythmFamily, rhythmSetNo, newRhythmSetId } = getRenamePayloadFromRow(row);

    const response = await authFetch(`${API_BASE_URL}/api/rhythm-sets/${encodeURIComponent(rhythmSetId)}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            newRhythmSetId,
            rhythmFamily,
            rhythmSetNo,
            status,
            notes
        })
    });

    if (!response.ok) {
        const err = await response.json().catch(() => ({ error: 'Failed to save rhythm set' }));
        throw new Error(err.error || 'Failed to save rhythm set');
    }

    return response.json();
}

async function renameRhythmSetRow(row) {
    const oldRhythmSetId = row.dataset.rhythmSetId;
    const status = row.querySelector('.set-status').value;
    const notes = row.querySelector('.set-notes').value;
    const { rhythmFamily, rhythmSetNo, newRhythmSetId } = getRenamePayloadFromRow(row);

    const response = await authFetch(`${API_BASE_URL}/api/rhythm-sets/${encodeURIComponent(oldRhythmSetId)}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            newRhythmSetId,
            rhythmFamily,
            rhythmSetNo,
            status,
            notes
        })
    });

    if (!response.ok) {
        const err = await response.json().catch(() => ({ error: 'Failed to rename rhythm set' }));
        throw new Error(err.error || 'Failed to rename rhythm set');
    }

    return response.json();
}

async function recomputeRhythmSet(rhythmSetId) {
    const response = await authFetch(`${API_BASE_URL}/api/rhythm-sets/${encodeURIComponent(rhythmSetId)}/recompute`, {
        method: 'PUT'
    });

    if (!response.ok) {
        const err = await response.json().catch(() => ({ error: 'Failed to recompute rhythm set' }));
        throw new Error(err.error || 'Failed to recompute rhythm set');
    }
}

async function deleteRhythmSet(rhythmSetId) {
    const response = await authFetch(`${API_BASE_URL}/api/rhythm-sets/${encodeURIComponent(rhythmSetId)}`, {
        method: 'DELETE'
    });

    if (!response.ok) {
        const err = await response.json().catch(() => ({ error: 'Failed to delete rhythm set' }));
        
        // Special handling for 404 - rhythm set not in database
        if (response.status === 404) {
            throw new Error(`Rhythm set "${rhythmSetId}" not found in database. It may only exist in loop files. Create it first or manually remove loop files.`);
        }
        
        throw new Error(err.error || 'Failed to delete rhythm set');
    }

    return response.json();
}

function wireEvents() {
    document.getElementById('refreshAllBtn').addEventListener('click', async () => {
        await initializeData();
    });

    document.getElementById('songSearchInput').addEventListener('input', filterSongs);

    // Handle select all checkbox in header
    document.getElementById('selectAllCheckbox').addEventListener('change', (e) => {
        const isChecked = e.target.checked;
        if (isChecked) {
            // Select all visible songs
            filteredSongs.forEach(song => {
                selectedSongIds.add(Number(song.id));
            });
        } else {
            // Deselect all visible songs
            filteredSongs.forEach(song => {
                selectedSongIds.delete(Number(song.id));
            });
        }
        renderSongsTable();
        updateSelectedSongCard();
    });

    // Handle select all button
    document.getElementById('selectAllBtn').addEventListener('click', () => {
        filteredSongs.forEach(song => {
            selectedSongIds.add(Number(song.id));
        });
        renderSongsTable();
        updateSelectedSongCard();
    });

    // Handle clear selection button
    document.getElementById('clearSelectionBtn').addEventListener('click', () => {
        selectedSongIds.clear();
        renderSongsTable();
        updateSelectedSongCard();
    });

    // Handle song table clicks
    document.getElementById('songsTableBody').addEventListener('click', (e) => {
        // Handle checkbox clicks
        const checkbox = e.target.closest('.song-checkbox');
        if (checkbox) {
            const songId = Number(checkbox.dataset.songId);
            if (checkbox.checked) {
                selectedSongIds.add(songId);
            } else {
                selectedSongIds.delete(songId);
            }
            renderSongsTable();
            updateSelectedSongCard();
            return;
        }

        // Handle select button clicks
        const button = e.target.closest('.select-song-btn');
        if (button) {
            const songId = Number(button.dataset.songId);
            setSelectedSong(songId);
            return;
        }
    });

    document.getElementById('mapperRhythmSetSelect').addEventListener('change', (e) => {
        updateSelectedSetMeta();
        renderPreviewButtons(e.target.value);
    });

    document.getElementById('assignBtn').addEventListener('click', async () => {
        await assignSelectedRhythmSet();
    });

    document.getElementById('recommendBtn').addEventListener('click', async () => {
        await recommendForSelectedSong();
    });

    document.getElementById('stopPreviewBtn').addEventListener('click', () => {
        stopPreview();
    });

    document.getElementById('stopAllPreviewBtn').addEventListener('click', () => {
        stopPreview();
    });

    document.getElementById('createRhythmSetForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        await createRhythmSet();
    });

    document.getElementById('rhythmSetsTableBody').addEventListener('click', async (e) => {
        const row = e.target.closest('tr[data-rhythm-set-id]');
        if (!row) return;

        const rhythmSetId = row.dataset.rhythmSetId;

        if (e.target.closest('.save-set-btn')) {
            try {
                showAlert(`Saving ${rhythmSetId}...`, 'info');
                const result = await saveRhythmSetRow(row);
                const savedRhythmSetId = result && result.rhythmSetId ? result.rhythmSetId : rhythmSetId;
                showAlert(`${rhythmSetId} saved as ${savedRhythmSetId}.`, 'success');
                clearAlertAfter();
                await Promise.all([loadRhythmSets(), loadSongs(), loadLoopsMetadata()]);
                setStats();
                updateSelectedSongCard();
            } catch (error) {
                showAlert(error.message, 'error');
            }
        }

        if (e.target.closest('.rename-set-btn')) {
            try {
                showAlert(`Renaming ${rhythmSetId}...`, 'info');
                const result = await renameRhythmSetRow(row);
                const newRhythmSetId = result && result.rhythmSetId ? result.rhythmSetId : rhythmSetId;
                showAlert(`${rhythmSetId} renamed to ${newRhythmSetId}.`, 'success');
                clearAlertAfter();
                await Promise.all([loadRhythmSets(), loadSongs(), loadLoopsMetadata()]);
                setStats();
                updateSelectedSongCard();
            } catch (error) {
                showAlert(error.message, 'error');
            }
        }

        if (e.target.closest('.recompute-set-btn')) {
            try {
                showAlert(`Recomputing ${rhythmSetId}...`, 'info');
                await recomputeRhythmSet(rhythmSetId);
                showAlert(`${rhythmSetId} recomputed.`, 'success');
                clearAlertAfter();
                await loadRhythmSets();
                setStats();
            } catch (error) {
                showAlert(error.message, 'error');
            }
        }

        if (e.target.closest('.use-set-btn')) {
            const select = document.getElementById('mapperRhythmSetSelect');
            select.value = rhythmSetId;
            updateSelectedSetMeta();
            renderPreviewButtons(rhythmSetId);
        }

        if (e.target.closest('.delete-set-btn')) {
            const rhythmSet = rhythmSets.find(set => set.rhythmSetId === rhythmSetId);
            const mappedCount = rhythmSet ? rhythmSet.mappedSongCount : 0;
            const isInDatabase = rhythmSet && (rhythmSet._id || rhythmSet.createdAt);
            
            // Check if this is a "loops-only" rhythm set
            if (!isInDatabase) {
                const loopFiles = loopsByRhythmSet.get(String(rhythmSetId || '').toLowerCase()) || {};
                const hasLoops = Object.keys(loopFiles).length > 0;
                
                if (hasLoops) {
                    alert(`Cannot delete "${rhythmSetId}".\n\nThis rhythm set only exists in loop files (not in database).\n\nTo remove it:\n1. Create it in the database first (using "Create" form above), OR\n2. Manually delete the loop files from the server`);
                } else {
                    alert(`Cannot delete "${rhythmSetId}".\n\nThis rhythm set was not found in the database.`);
                }
                return;
            }
            
            let confirmMessage = `Are you sure you want to delete rhythm set "${rhythmSetId}"?`;
            if (mappedCount > 0) {
                confirmMessage += `\n\nWarning: ${mappedCount} song(s) are currently mapped to this rhythm set. You must unmap them first.`;
            }
            confirmMessage += '\n\nThis action cannot be undone.';
            
            if (!confirm(confirmMessage)) {
                return;
            }

            try {
                showAlert(`Deleting ${rhythmSetId}...`, 'info');
                await deleteRhythmSet(rhythmSetId);
                showAlert(`${rhythmSetId} deleted successfully.`, 'success');
                clearAlertAfter();
                await Promise.all([loadRhythmSets(), loadSongs(), loadLoopsMetadata()]);
                setStats();
            } catch (error) {
                showAlert(error.message, 'error');
                clearAlertAfter(5000);
            }
        }

        if (e.target.closest('.preview-loop-btn')) {
            const button = e.target.closest('.preview-loop-btn');
            const filename = button.dataset.filename;
            const label = button.dataset.label;
            
            if (filename) {
                const url = `${API_BASE_URL}/loops/${encodeURIComponent(filename)}`;
                playPreview(url, button);
            }
        }
    });
}

async function initializeData() {
    if (!isAuthenticated()) {
        showAlert('Login required. Open the main app first, then return to this page.', 'error');
        return;
    }

    try {
        showAlert('Loading songs, rhythm sets, and loop previews...', 'info');
        await Promise.all([loadSongs(), loadRhythmSets(), loadLoopsMetadata()]);
        setStats();
        updateSelectedSetMeta();
        showAlert('Ready.', 'success');
        clearAlertAfter();
    } catch (error) {
        showAlert(error.message || 'Failed to initialize rhythm mapper.', 'error');
    }
}

document.addEventListener('DOMContentLoaded', async () => {
    applyThemeFromStorage();
    wireEvents();
    wireQuickCreateModal();
    await initializeData();
});

// ======================== QUICK CREATE MODAL ========================

let quickCreateSelectedSongs = new Set();
let quickCreateLoopFiles = [];

function wireQuickCreateModal() {
    const modal = document.getElementById('quickCreateModal');
    const openBtn = document.getElementById('quickCreateBtn');
    const closeBtn = document.getElementById('closeQuickCreate');
    const cancelBtn = document.getElementById('cancelQuickCreate');
    const executeBtn = document.getElementById('executeQuickCreate');
    const uploadArea = document.getElementById('uploadArea');
    const fileInput = document.getElementById('loopFilesInput');
    const songSearch = document.getElementById('qc_songSearch');
    const familyInput = document.getElementById('qc_rhythmFamily');
    const setNoSelect = document.getElementById('qc_rhythmSetNo');

    // Open modal
    openBtn.addEventListener('click', () => {
        resetQuickCreateModal();
        renderQuickCreateSongList();
        modal.classList.add('active');
    });

    // Close modal
    const closeModal = () => {
        modal.classList.remove('active');
        resetQuickCreateModal();
    };

    closeBtn.addEventListener('click', closeModal);
    cancelBtn.addEventListener('click', closeModal);
    
    modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });

    // Handle rhythm family change
    familyInput.addEventListener('input', () => {
        updateAvailableSetNumbers();
        updateRhythmSetPreview();
        showExistingLoops();
    });

    // Handle set number change
    setNoSelect.addEventListener('change', () => {
        updateRhythmSetPreview();
    });

    // File upload
    uploadArea.addEventListener('click', () => fileInput.click());
    
    uploadArea.addEventListener('dragover', (e) => {
        e.preventDefault();
        uploadArea.classList.add('dragover');
    });

    uploadArea.addEventListener('dragleave', () => {
        uploadArea.classList.remove('dragover');
    });

    uploadArea.addEventListener('drop', (e) => {
        e.preventDefault();
        uploadArea.classList.remove('dragover');
        const files = Array.from(e.dataTransfer.files).filter(f => f.type === 'audio/mpeg' || f.name.endsWith('.mp3'));
        addQuickCreateFiles(files);
    });

    fileInput.addEventListener('change', (e) => {
        const files = Array.from(e.target.files);
        addQuickCreateFiles(files);
    });

    // Song search
    songSearch.addEventListener('input', () => {
        renderQuickCreateSongList();
    });

    // Execute quick create
    executeBtn.addEventListener('click', async () => {
        await executeQuickCreate();
    });
}

function resetQuickCreateModal() {
    document.getElementById('qc_rhythmFamily').value = '';
    document.getElementById('qc_rhythmSetNo').innerHTML = '<option value="">Set #</option>';
    document.getElementById('qc_status').value = 'active';
    document.getElementById('qc_notes').value = '';
    document.getElementById('qc_songSearch').value = '';
    document.getElementById('loopFilesInput').value = '';
    document.getElementById('fileList').innerHTML = '';
    document.getElementById('quickCreateProgress').innerHTML = '';
    document.getElementById('quickCreateProgress').classList.remove('active');
    document.getElementById('qc_rhythmSetPreview').style.display = 'none';
    document.getElementById('qc_existingLoops').style.display = 'none';
    
    quickCreateSelectedSongs.clear();
    quickCreateLoopFiles = [];
    
    document.getElementById('step1Indicator').classList.remove('complete');
    document.getElementById('step2Indicator').classList.remove('complete');
    document.getElementById('step3Indicator').classList.remove('complete');
    
    updateQuickCreateSongCount();
}

function updateAvailableSetNumbers() {
    const family = normalizeRhythmFamily(document.getElementById('qc_rhythmFamily').value);
    const setNoSelect = document.getElementById('qc_rhythmSetNo');
    
    if (!family) {
        setNoSelect.innerHTML = '<option value="">Set #</option>';
        return;
    }

    // Find existing set numbers for this family
    const existingSetNos = rhythmSets
        .filter(set => normalizeRhythmFamily(set.rhythmFamily) === family)
        .map(set => set.rhythmSetNo)
        .sort((a, b) => a - b);

    // Generate available set numbers (1-20, excluding existing)
    const maxSetNo = Math.max(20, ...existingSetNos, 0);
    const availableNumbers = [];
    
    for (let i = 1; i <= maxSetNo + 1; i++) {
        if (!existingSetNos.includes(i)) {
            availableNumbers.push(i);
        }
    }

    // Populate select
    setNoSelect.innerHTML = '<option value="">Select available set #</option>';
    availableNumbers.forEach(num => {
        const option = document.createElement('option');
        option.value = num;
        option.textContent = `Set ${num} (new)`;
        setNoSelect.appendChild(option);
    });

    // Show existing numbers as disabled options for reference
    if (existingSetNos.length > 0) {
        const divider = document.createElement('option');
        divider.disabled = true;
        divider.textContent = '--- Existing Sets ---';
        setNoSelect.appendChild(divider);

        existingSetNos.forEach(num => {
            const option = document.createElement('option');
            option.value = num;
            option.disabled = true;
            option.textContent = `Set ${num} (already exists)`;
            setNoSelect.appendChild(option);
        });
    }
}

function updateRhythmSetPreview() {
    const family = normalizeRhythmFamily(document.getElementById('qc_rhythmFamily').value);
    const setNo = document.getElementById('qc_rhythmSetNo').value;
    const previewDiv = document.getElementById('qc_rhythmSetPreview');
    const nameSpan = document.getElementById('qc_rhythmSetName');

    if (family && setNo) {
        const rhythmSetId = buildRhythmSetId(family, parseInt(setNo, 10));
        nameSpan.textContent = rhythmSetId;
        previewDiv.style.display = 'block';
    } else {
        previewDiv.style.display = 'none';
    }
}

function showExistingLoops() {
    const family = normalizeRhythmFamily(document.getElementById('qc_rhythmFamily').value);
    const existingDiv = document.getElementById('qc_existingLoops');
    const listDiv = document.getElementById('qc_existingLoopsList');

    if (!family) {
        existingDiv.style.display = 'none';
        return;
    }

    // Find all rhythm sets for this family
    const familySets = rhythmSets.filter(set => 
        normalizeRhythmFamily(set.rhythmFamily) === family
    ).sort((a, b) => a.rhythmSetNo - b.rhythmSetNo);

    if (familySets.length === 0) {
        existingDiv.style.display = 'none';
        return;
    }

    // Build list of existing sets with their loop counts
    const setsList = familySets.map(set => {
        const loopCount = (set.availableFiles || []).length;
        return `${set.rhythmSetId} (${loopCount}/6 loops)`;
    }).join(', ');

    listDiv.textContent = setsList;
    existingDiv.style.display = 'block';
}

function addQuickCreateFiles(files) {
    files.forEach(file => {
        // Check if file already added
        if (!quickCreateLoopFiles.find(f => f.name === file.name)) {
            quickCreateLoopFiles.push(file);
        }
    });
    renderQuickCreateFileList();
}

function renderQuickCreateFileList() {
    const fileList = document.getElementById('fileList');
    fileList.innerHTML = '';

    if (quickCreateLoopFiles.length === 0) {
        return;
    }

    quickCreateLoopFiles.forEach((file, index) => {
        const li = document.createElement('li');
        li.innerHTML = `
            <span><i class="fas fa-music"></i> ${escapeHtml(file.name)} (${(file.size / 1024).toFixed(1)} KB)</span>
            <span class="remove-file" data-index="${index}">×</span>
        `;
        fileList.appendChild(li);
    });

    // Add remove file handlers
    fileList.querySelectorAll('.remove-file').forEach(btn => {
        btn.addEventListener('click', () => {
            const index = parseInt(btn.dataset.index);
            quickCreateLoopFiles.splice(index, 1);
            renderQuickCreateFileList();
        });
    });
}

function renderQuickCreateSongList() {
    const selector = document.getElementById('songSelector');
    const searchTerm = document.getElementById('qc_songSearch').value.toLowerCase();
    
    const filteredSongs = songs.filter(song => {
        if (!searchTerm) return true;
        const haystack = [
            song.title,
            song.taal,
            song.key,
            song.tempo,
            song.id
        ].map(v => String(v || '').toLowerCase()).join(' ');
        return haystack.includes(searchTerm);
    });

    if (filteredSongs.length === 0) {
        selector.innerHTML = '<p style="margin:0; text-align:center; color:#999;">No songs found</p>';
        return;
    }

    selector.innerHTML = '';
    filteredSongs.forEach(song => {
        const div = document.createElement('div');
        div.className = 'song-checkbox-item';
        const isChecked = quickCreateSelectedSongs.has(Number(song.id));
        
        div.innerHTML = `
            <input type="checkbox" ${isChecked ? 'checked' : ''} data-song-id="${song.id}">
            <label style="cursor:pointer; flex:1; margin:0;">
                <strong>${escapeHtml(song.title)}</strong>
                <span class="small-note"> - ${escapeHtml(song.taal || 'No taal')} | ${escapeHtml(song.key || '-')}</span>
            </label>
        `;
        
        const checkbox = div.querySelector('input[type="checkbox"]');
        checkbox.addEventListener('change', () => {
            const songId = Number(checkbox.dataset.songId);
            if (checkbox.checked) {
                quickCreateSelectedSongs.add(songId);
            } else {
                quickCreateSelectedSongs.delete(songId);
            }
            updateQuickCreateSongCount();
        });
        
        div.querySelector('label').addEventListener('click', () => {
            checkbox.click();
        });
        
        selector.appendChild(div);
    });
}

function updateQuickCreateSongCount() {
    document.getElementById('selectedSongsCount').textContent = quickCreateSelectedSongs.size;
}

function showQuickCreateProgress(message) {
    const progressDiv = document.getElementById('quickCreateProgress');
    progressDiv.textContent = message;
    progressDiv.classList.add('active');
}

async function executeQuickCreate() {
    const family = document.getElementById('qc_rhythmFamily').value.trim();
    const setNo = parseInt(document.getElementById('qc_rhythmSetNo').value, 10);
    const status = document.getElementById('qc_status').value;
    const notes = document.getElementById('qc_notes').value.trim();

    // Validation
    if (!family || !setNo || setNo <= 0) {
        alert('Please enter a rhythm family and set number.');
        return;
    }

    const rhythmSetId = buildRhythmSetId(family, setNo);
    if (!rhythmSetId) {
        alert('Invalid rhythm set ID format.');
        return;
    }

    try {
        // Step 1: Create rhythm set
        showQuickCreateProgress('Step 1/3: Creating rhythm set...');
        const createResponse = await authFetch(`${API_BASE_URL}/api/rhythm-sets`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                rhythmFamily: normalizeRhythmFamily(family),
                rhythmSetNo: setNo,
                status,
                notes
            })
        });

        if (!createResponse.ok) {
            const err = await createResponse.json().catch(() => ({ error: 'Failed to create rhythm set' }));
            throw new Error(err.error || 'Failed to create rhythm set');
        }

        document.getElementById('step1Indicator').classList.add('complete');

        // Step 2: Upload loops (if any)
        if (quickCreateLoopFiles.length > 0) {
            showQuickCreateProgress(`Step 2/3: Uploading ${quickCreateLoopFiles.length} loop file(s)...`);
            
            for (const file of quickCreateLoopFiles) {
                const formData = new FormData();
                formData.append('loopFile', file);
                formData.append('rhythmSetId', rhythmSetId);
                
                // Try to detect loop type from filename
                const lowerName = file.name.toLowerCase();
                let type = 'loop';
                let number = 1;
                
                if (lowerName.includes('loop')) {
                    type = 'loop';
                    if (lowerName.includes('1')) number = 1;
                    else if (lowerName.includes('2')) number = 2;
                    else if (lowerName.includes('3')) number = 3;
                } else if (lowerName.includes('fill')) {
                    type = 'fill';
                    if (lowerName.includes('1')) number = 1;
                    else if (lowerName.includes('2')) number = 2;
                    else if (lowerName.includes('3')) number = 3;
                }
                
                formData.append('type', type);
                formData.append('number', number);

                const uploadResponse = await authFetch(`${API_BASE_URL}/api/loops/upload`, {
                    method: 'POST',
                    body: formData
                });

                if (!uploadResponse.ok) {
                    console.warn(`Failed to upload ${file.name}`);
                }
            }
            
            document.getElementById('step2Indicator').classList.add('complete');
        } else {
            showQuickCreateProgress('Step 2/3: Skipping loop upload...');
        }

        // Step 3: Assign songs (if any)
        if (quickCreateSelectedSongs.size > 0) {
            showQuickCreateProgress(`Step 3/3: Assigning ${quickCreateSelectedSongs.size} song(s)...`);
            
            const parsed = parseRhythmSetId(rhythmSetId);
            for (const songId of quickCreateSelectedSongs) {
                const assignResponse = await authFetch(`${API_BASE_URL}/api/songs/${songId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        rhythmSetId: parsed.rhythmSetId,
                        rhythmFamily: parsed.rhythmFamily,
                        rhythmSetNo: parsed.rhythmSetNo
                    })
                });

                if (!assignResponse.ok) {
                    console.warn(`Failed to assign song ${songId}`);
                }
            }
            
            document.getElementById('step3Indicator').classList.add('complete');
        } else {
            showQuickCreateProgress('Step 3/3: Skipping song assignment...');
        }

        // Success!
        showQuickCreateProgress(`✓ Success! Rhythm set "${rhythmSetId}" created!`);
        
        setTimeout(async () => {
            document.getElementById('quickCreateModal').classList.remove('active');
            showAlert(`Rhythm set "${rhythmSetId}" created successfully!`, 'success');
            clearAlertAfter();
            await Promise.all([loadSongs(), loadRhythmSets(), loadLoopsMetadata()]);
            setStats();
            resetQuickCreateModal();
        }, 1500);

    } catch (error) {
        showQuickCreateProgress(`✗ Error: ${error.message}`);
        setTimeout(() => {
            document.getElementById('quickCreateProgress').classList.remove('active');
        }, 5000);
    }
}
