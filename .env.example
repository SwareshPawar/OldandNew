# Copy this file to .env and fill in real values before running locally.
# Never commit the real .env file — it must be in .gitignore.

# ─── Required ─────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/OldNewSongs

# JWT signing secret — use a strong random string, minimum 64 characters
JWT_SECRET=replace-with-a-long-random-secret

# ─── Server ───────────────────────────────────────────────────────────────────

# API server port (default: 3001)
# api-base.js in the browser resolves localhost API calls to port 3001.
# If you change this, update scripts/core/api-base.js to match.
PORT=3001

NODE_ENV=development

# ─── Email (OTP password reset — optional) ────────────────────────────────────

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-password-or-app-password

# ─── Twilio SMS (OTP password reset — optional) ───────────────────────────────

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number
